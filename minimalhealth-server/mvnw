MAVEN_HOME=".mvn/wrapper"
MAVEN_OPTS="-Xmx512m"
CLASSPATH=".mvn/wrapper/maven-wrapper.jar"

# Find java: try JAVA_HOME first, then fallback to PATH
if [ -n "$JAVA_HOME" ] && [ -x "${JAVA_HOME}/bin/java" ]; then
  JAVA_CMD="${JAVA_HOME}/bin/java"
else
  JAVA_CMD="$(command -v java 2>/dev/null)" || JAVA_CMD="java"
fi

"$JAVA_CMD" $MAVEN_OPTS -Dmaven.multiModuleProjectDirectory="$(pwd)" -classpath "$CLASSPATH" org.apache.maven.wrapper.MavenWrapperMain "$@"
